#!/bin/sh
# rtsp-server (mediamtx) init (BusyBox)
#   프로비저닝(S20) 완료 전에는 기동 보류(서비스 게이트).
#   기동 시 stream.env 의 viewer/publisher 자격을 설정 템플릿에 주입해 런타임 설정 생성.
DAEMON=/usr/bin/mediamtx
TEMPLATE=/etc/mediamtx.yml
RUNTIME=/run/mediamtx.runtime.yml
TLSDIR=/data/tls
STREAM=/data/cred/stream.env

case "$1" in
	start)
		# SFR:1.4.1/3.4.3 미프로비저닝 상태에서 정상 서비스 차단(fail-closed)
		if [ ! -f /data/.provisioned ]; then
			echo "rtsp-server: 미프로비저닝 — 기동 보류(프로비저닝 후 개방)"; exit 0
		fi
		# SFR:1.2.1 인증서 없으면 평문 폴백 금지 — 기동 보류
		if [ ! -f "$TLSDIR/server.crt" ] || [ ! -f "$TLSDIR/server.key" ]; then
			echo "rtsp-server: TLS 인증서 없음 — 기동 보류"; exit 1
		fi
		# SFR:1.1.1 영상 계정 자격 주입(익명 접근 차단)
		if [ ! -f "$STREAM" ]; then
			echo "rtsp-server: 스트림 자격 없음 — 기동 보류"; exit 1
		fi
		# shellcheck disable=SC1090
		. "$STREAM"
		umask 077
		sed -e "s|__VIEWER_PW__|$VIEWER_PW|" \
		    -e "s|__PUBLISHER_PW__|$PUBLISHER_PW|" "$TEMPLATE" > "$RUNTIME"
		printf "Starting rtsp-server: "
		# mediamtx 출력을 읽기가능 로그로 캡처(운영/디버깅). 자격증명은 RUNTIME(600)에만 존재.
		$DAEMON "$RUNTIME" >/var/log/mediamtx.log 2>&1 &
		chmod 0644 /var/log/mediamtx.log 2>/dev/null
		echo "OK" ;;
	stop)   printf "Stopping rtsp-server: "; killall mediamtx 2>/dev/null; rm -f "$RUNTIME"; echo "OK" ;;
	restart) "$0" stop; "$0" start ;;
	*) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
