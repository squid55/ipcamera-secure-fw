#!/bin/sh
# rtsp-server (mediamtx) init (BusyBox)
DAEMON=/usr/bin/mediamtx
CONF=/etc/mediamtx.yml
case "$1" in
	start)
		# RTSPS 인증서 없으면 기동 보류(SFR:1.2.1 — 평문 폴백 금지)
		if [ ! -f /etc/ssl/rtsp/server.crt ]; then
			echo "rtsp-server: 서버 인증서 없음 — 프로비저닝 후 기동"; exit 1
		fi
		printf "Starting rtsp-server: "; $DAEMON $CONF & echo "OK" ;;
	stop)   printf "Stopping rtsp-server: "; killall mediamtx 2>/dev/null; echo "OK" ;;
	restart) "$0" stop; "$0" start ;;
	*) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
