#!/bin/sh
# S15mountdata — 쓰기가능 데이터 영역(/data) 준비
#   상태·비밀(관리 자격증명·TLS 키·감사)은 읽기전용 root(dm-verity, SFR:5.2.1) 밖의
#   별도 쓰기가능 파티션에 둔다. 양산: LABEL=data 전용 파티션.
#   프로토타입(현 단순 ext4 이미지): 전용 파티션 없으면 rootfs /data 폴백(개발용).
DATA=/data

start() {
	mkdir -p "$DATA"
	if [ -e /dev/disk/by-label/data ]; then
		mount -t ext4 /dev/disk/by-label/data "$DATA" 2>/dev/null \
			&& echo "S15mountdata: 전용 data 파티션 마운트"
	fi
	if ! grep -q " $DATA " /proc/mounts 2>/dev/null; then
		echo "S15mountdata: 전용 data 파티션 없음 — rootfs /data 사용(프로토타입/개발)"
	fi
	# 비밀 디렉터리 권한(자격증명·TLS 키는 root 전용)
	mkdir -p "$DATA/cred" "$DATA/tls"
	chmod 700 "$DATA/cred" "$DATA/tls"
}

case "$1" in
	start) start ;;
	stop)  : ;;
	restart) : ;;
	*) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac
